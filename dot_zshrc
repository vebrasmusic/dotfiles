. "$HOME/.local/bin/env"

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

source <(fzf --zsh)

alias sirch_browser="cd ~/Documents/GitHub/sirch_browser"
